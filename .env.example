# Application
APP_NAME="AI Triage Service"
ENVIRONMENT=local
LOG_LEVEL=INFO

# OpenAI / LLM
# Do not commit a real key to GitHub.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# For local demo/testing without paid API calls:
# true = deterministic local demo classifier; false = real OpenAI call
LLM_FAKE_MODE=false

# Reliability
REQUESTS_PER_MINUTE=10

# Storage/logs
DB_PATH=data/tickets.db
LOG_FILE=logs/app.log
